# Copy to .env (do not commit .env). Each developer maintains their own file locally.

PORT=5000

# MongoDB Atlas — SRV string from Atlas → Connect → Drivers.
# Network Access must allow your IP (or 0.0.0.0/0 for shared dev — ask project admin).
# Replace USER, PASSWORD, cluster host, and appName with your project values.
MONGO_URI=mongodb+srv://USER:PASSWORD@trojanpayrollsolutions.ms7z6vt.mongodb.net/payroll_db?appName=TrojanPayrollSolutions

# If you see querySrv ECONNREFUSED for mongodb+srv, uncomment and use public DNS for this process only:
# MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=mySuperSecretKey345

# Comma-separated browser origins (Vite: 5173; static serve: 3000)
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

NODE_ENV=development
